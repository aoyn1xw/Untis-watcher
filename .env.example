# ── WebUntis credentials (REQUIRED) ─────────────────────────────────────────
# The hostname shown in the WebUntis URL, e.g. melpomene.webuntis.com
UNTIS_SERVER=melpomene.webuntis.com

# The school slug exactly as it appears in the WebUntis URL
UNTIS_SCHOOL=your-school-slug

# Your WebUntis login username
UNTIS_USER=your.username

# Your WebUntis login password
UNTIS_PASSWORD=your-password

# ── Telegram (REQUIRED) ──────────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff-example

# Chat ID to send notifications to (use @userinfobot to find yours)
TELEGRAM_CHAT_ID=987654321

# ── WebUntis element (REQUIRED) ──────────────────────────────────────────────
# Your numeric class or student ID from the WebUntis API
UNTIS_ELEMENT_ID=12345

# Element type: 5=class/student (default), 2=teacher
# UNTIS_ELEMENT_TYPE=5

# ── WebUntis advanced / optional ─────────────────────────────────────────────
# UNTIS_TENANT_ID=
# UNTIS_CLIENT_ID=
# UNTIS_API_PASSWORD=

# ── AI / OpenAI-compatible endpoint (optional) ───────────────────────────────
# Set AI_ENABLED=false to skip the AI model entirely and always use the
# structured plain-text summary. Defaults to true when AI_API_KEY is present.
# AI_ENABLED=true

# API key for your chosen endpoint
# AI_API_KEY=sk-...

# Custom base URL for any OpenAI-compatible endpoint.
# Leave unset to use the default OpenAI API (api.openai.com).
# Examples:
#   GitHub Models:  https://models.github.ai/inference
#   LM Studio:      http://localhost:1234/v1
#   Ollama:         http://localhost:11434/v1
#   Together AI:    https://api.together.xyz/v1
# AI_BASE_URL=

# Model name to use (default: gpt-4o-mini)
# AI_MODEL=gpt-4o-mini

# ── Polling behaviour (optional) ─────────────────────────────────────────────
# Seconds between WebUntis polls (default: 300)
# POLL_INTERVAL=300

# How many days ahead to fetch from WebUntis (default: 7)
# DAYS_AHEAD=7

# ── Health monitoring (optional) ─────────────────────────────────────────────
# Send a Telegram heartbeat every N seconds to confirm the watcher is alive.
# Set to 0 (default) to disable heartbeat messages.
# Example: 3600 = hourly heartbeat
# HEARTBEAT_INTERVAL=0

# Send a Telegram alert after this many consecutive fetch failures (default: 3)
# FAILURE_ALERT_THRESHOLD=3
